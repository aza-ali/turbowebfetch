{
  "name": "turbowebfetch",
  "version": "1.0.0",
  "description": "Every agent gets its own browser. 14 agents? 14 browsers - all running in parallel at AI speed. Works where vanilla automation fails.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "setup:python": "bash python/setup.sh",
    "postinstall": "echo \"\nTurboWebFetch - every agent gets its own browser\nBy Mourtaza Ali | mourtaza.com\n\nRun 'npm run setup:python' to install Python/nodriver support.\n\""
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "web-content",
    "browser-rendering",
    "parallel-fetch",
    "claude-code",
    "model-context-protocol"
  ],
  "author": "Mourtaza Ali <aza.a.ali@gmail.com> (https://mourtaza.com)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.5.0",
    "jsdom": "^24.0.0",
    "turndown": "^7.1.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.0.0",
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
