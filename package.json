{
  "name": "turbowebfetch",
  "version": "1.0.0",
  "description": "Turn websites into LLM-ready data, locally. Handles dynamic JS, Cloudflare, and rendering automatically. 14 parallel browsers. Zero API keys.",
  "main": "dist/index.js",
  "bin": {
    "turbowebfetch": "dist/index.js"
  },
  "type": "module",
  "files": [
    "dist",
    "python/fetcher.py",
    "python/human_mouse.py",
    "python/human_scroll.py",
    "python/human_timing.py",
    "python/requirements.txt",
    "python/setup.sh",
    "scripts/postinstall.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "setup:python": "bash python/setup.sh",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "mcp",
    "ai-agents",
    "web-content",
    "browser-rendering",
    "parallel-fetch",
    "claude-code",
    "model-context-protocol",
    "nodriver",
    "javascript-rendering",
    "dynamic-content",
    "headless-chrome",
    "content-extraction",
    "web-automation"
  ],
  "author": "Mourtaza Ali <aza.a.ali@gmail.com> (https://mourtaza.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AzaaliDev/turbowebfetch.git"
  },
  "bugs": {
    "url": "https://github.com/AzaaliDev/turbowebfetch/issues"
  },
  "homepage": "https://github.com/AzaaliDev/turbowebfetch#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.56.0",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
